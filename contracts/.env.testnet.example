# BNB Testnet deployment profile
# Copy to .env and fill all 0x... placeholders with real values.

RPC_URL=https://bsc-testnet.publicnode.com
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

OWNER_ADDRESS=0x0000000000000000000000000000000000000000
SAFE_ADDRESS=0x0000000000000000000000000000000000000000
AGENT_ADDRESS=0x0000000000000000000000000000000000000000

# Deploy adapter in-script or use an existing one
DEPLOY_ORACLE_ADAPTER=true
ORACLE_ADDRESS=0x0000000000000000000000000000000000000000
NATIVE_TOKEN_DECIMALS=18

MAX_DAILY_VOLUME=1000000000000000000000
COOLDOWN_SECONDS=3600
MAX_DEADLINE_DELAY_SECONDS=1800
MAX_ORACLE_STALENESS_SECONDS=300
MAX_ORACLE_DEVIATION_BPS=300

# Routers and selectors
ALLOWED_ROUTERS=0x0000000000000000000000000000000000000000
# Decimal uint32 selectors, comma-separated
ALLOWED_FUNCTION_SELECTORS=1095492489

# Tokens and limits (aligned index positions)
ALLOWED_TOKENS=0x0000000000000000000000000000000000000000
MIN_TRADE_AMOUNTS=1000000000000000000
TOKEN_MAX_DAILY_VOLUMES=1000000000000000000000

# Oracle feed wiring (aligned index positions)
ORACLE_FEED_TOKEN_INS=0x0000000000000000000000000000000000000000
ORACLE_FEED_TOKEN_OUTS=0x0000000000000000000000000000000000000000
ORACLE_FEED_ADDRESSES=0x0000000000000000000000000000000000000000
ORACLE_FEED_INVERSE_FLAGS=0

# Fill after deployment for config validation
GUARD_ADDRESS=0x0000000000000000000000000000000000000000
MODULE_ADDRESS=0x0000000000000000000000000000000000000000
