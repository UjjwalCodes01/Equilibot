# Frontend Environment Variables

# ── Required ──────────────────────────────────────────────────────────────────

# Gemini API key for AI narration, explainability, and strategy studio
GEMINI_API_KEY=your_gemini_api_key_here

# Agent telemetry base URL (Render service URL)
# Local dev: http://127.0.0.1:9100
AGENT_TELEMETRY_BASE_URL=https://equilibot.onrender.com

# Optional: bearer token to protect agent telemetry endpoints (recommended in production)
AGENT_TELEMETRY_API_TOKEN=replace-with-long-random-token

# ── Optional ──────────────────────────────────────────────────────────────────

# RPC endpoints (override defaults if needed)
NEXT_PUBLIC_BNB_TESTNET_RPC_URL=https://bsc-testnet-rpc.publicnode.com
NEXT_PUBLIC_BNB_MAINNET_RPC_URL=https://bsc-dataseed.binance.org

# Contract addresses (BNB testnet defaults from current deployment)
NEXT_PUBLIC_SAFE_ADDRESS=0x19223058050D2C91E6e42158f0760340Fb3D41C3
NEXT_PUBLIC_MODULE_ADDRESS=0xe963752aD278ff5185e16C46bB75C6c8b87641D6
NEXT_PUBLIC_GUARD_ADDRESS=0xba6c8EEaDB62Dc0302bEBb3d80C0AEA459af2Dc1

# WalletConnect Project ID for wagmi/RainbowKit (get from cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
