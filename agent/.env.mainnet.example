# ============================================================
# EquiliBot Agent Mainnet Production Configuration (BSC)
# ============================================================
# This file is for production operators. Copy to .env and fill
# only the project-specific values marked below.

# --- RPC Endpoints (must be production-grade, low-latency) ---
RPC_HTTP_URL=https://your-bsc-mainnet-https-endpoint
RPC_WSS_URL=wss://your-bsc-mainnet-wss-endpoint
RPC_PRIVATE_URL=https://your-private-rpc-for-managed-signer
CHAIN_ID=56

# --- Signer Mode (required for mainnet) ---
SIGNER_MODE=managed
# Managed signer address (the authorized agent address on EquiliBotModule)
MANAGED_SIGNER_ADDRESS=0xYOUR_MANAGED_SIGNER_ADDRESS

# Local private key is intentionally unused on mainnet mode
# AGENT_PRIVATE_KEY=

# Must be true only after external security review is completed
SECURITY_REVIEW_SIGNED_OFF=true

# --- Deployed Production Contracts (project-specific) ---
SAFE_ADDRESS=0xYOUR_MAINNET_SAFE_ADDRESS
MODULE_ADDRESS=0xYOUR_MAINNET_MODULE_ADDRESS
GUARD_ADDRESS=0xYOUR_MAINNET_GUARD_ADDRESS

# --- PancakeSwap V3 Mainnet Canonical Addresses ---
PANCAKE_V3_FACTORY=0x0BFbCF9fa4f9C56B0F40a671Ad40E0805A091865
PANCAKE_SMART_ROUTER=0x13f4EA83D0bd40E75C8222255bc855a974568Dd4
PANCAKE_QUOTER_V2=0xB048Bbc1Ee6b733FFfCFb9e9CeF7375518e25997

# --- Pyth Oracle ---
PYTH_HERMES_URL=https://hermes.pyth.network

# --- Agent Tuning ---
POLL_INTERVAL_MS=5000
MIN_PROFIT_MULTIPLIER=1.5
MIN_DEVIATION_BPS=50
MAX_CONSECUTIVE_FAILURES=5
SIMULATION_TIMEOUT_MS=10000
MAX_GAS_PRICE_MULTIPLIER=3
