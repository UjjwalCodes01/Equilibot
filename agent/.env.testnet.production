# ============================================================
# EquiliBot Testnet Production Profile (Hackathon)
# ============================================================
# Usage:
# 1) Copy this profile into .env (or run npm run env:use:testnet)
# 2) Set AGENT_PRIVATE_KEY to your dedicated testnet key
# 3) Keep execution in canary during hackathon for controlled real swaps

# --- RPC Endpoints ---
RPC_HTTP_URL=https://bsc-testnet-rpc.publicnode.com
RPC_WSS_URL=wss://bsc-testnet-rpc.publicnode.com
# Optional now; required when switching to managed signer
RPC_PRIVATE_URL=https://bsc-testnet-rpc.publicnode.com
CHAIN_ID=97

# --- Signer (testnet-first) ---
SIGNER_MODE=local
AGENT_PRIVATE_KEY=replace-with-dedicated-testnet-key

# Managed signer placeholders for easy migration
# MANAGED_SIGNER_ADDRESS=0xYOUR_MANAGED_SIGNER_ADDRESS
# MANAGED_SIGNER_PROVIDER=aws-kms
# AWS_REGION=us-east-1
# AWS_KMS_KEY_ID=replace-with-real-aws-kms-key-id

SECURITY_REVIEW_SIGNED_OFF=false

# --- Deployed Contracts (current testnet) ---
SAFE_ADDRESS=0x19223058050D2C91E6e42158f0760340Fb3D41C3
MODULE_ADDRESS=0xe963752aD278ff5185e16C46bB75C6c8b87641D6
GUARD_ADDRESS=0xba6c8EEaDB62Dc0302bEBb3d80C0AEA459af2Dc1

# --- PancakeSwap V3 ---
PANCAKE_V3_FACTORY=0x0BFbCF9fa4f9C56B0F40a671Ad40E0805A091865
PANCAKE_SMART_ROUTER=0x13f4EA83D0bd40E75C8222255bc855a974568Dd4
PANCAKE_QUOTER_V2=0xbC203d7f83677c7ed3F7acEc959963E7F4ECC5C2

# --- Oracle ---
PYTH_HERMES_URL=https://hermes.pyth.network

# --- Tuning ---
POLL_INTERVAL_MS=5000
MIN_PROFIT_MULTIPLIER=1.5
MIN_DEVIATION_BPS=50
MAX_CONSECUTIVE_FAILURES=5
SIMULATION_TIMEOUT_MS=10000
MAX_GAS_PRICE_MULTIPLIER=3

# --- Execution Controls ---
EXECUTION_MODE=canary
CANARY_MAX_TRADE_USD=100
RUNTIME_MAX_NOTIONAL_USD=500

# --- Telemetry ---
TELEMETRY_PORT=9100
TELEMETRY_BIND_ADDRESS=127.0.0.1
TELEMETRY_ALLOWED_ORIGIN=http://localhost:3000
TELEMETRY_API_TOKEN=replace-with-long-random-telemetry-token

# --- Alerting ---
ALERT_WEBHOOK_URL=https://example.com/equilibot-alert-webhook
ALERT_MIN_SEVERITY=warn
ALERT_DEDUP_COOLDOWN_MS=300000
ALERT_POLICY_REJECTION_WINDOW_MIN=10
ALERT_POLICY_REJECTION_THRESHOLD=5
ALERT_ORACLE_NULL_WINDOW_MIN=10
ALERT_ORACLE_NULL_THRESHOLD=5
ALERT_RPC_CHECK_INTERVAL_MS=30000
ALERT_RPC_FAILURE_THRESHOLD=3
