# ============================================================
# EquiliBot Mainnet Production Profile (Post-Hackathon)
# ============================================================
# Usage:
# 1) Run npm run env:use:mainnet
# 2) Fill all replace-* values below
# 3) Keep canary first, then promote to active after successful soak + review

# --- RPC Endpoints ---
RPC_HTTP_URL=https://your-bsc-mainnet-https-endpoint
RPC_WSS_URL=wss://your-bsc-mainnet-wss-endpoint
RPC_PRIVATE_URL=https://your-private-rpc-for-managed-signer
CHAIN_ID=56

# --- Signer (required on mainnet) ---
SIGNER_MODE=managed
MANAGED_SIGNER_ADDRESS=0xYOUR_MAINNET_MANAGED_SIGNER_ADDRESS
MANAGED_SIGNER_PROVIDER=aws-kms
AWS_REGION=us-east-1
AWS_KMS_KEY_ID=replace-with-real-aws-kms-key-id

# Must be true only after external security review completion
SECURITY_REVIEW_SIGNED_OFF=false

# --- Deployed Production Contracts ---
SAFE_ADDRESS=0xYOUR_MAINNET_SAFE_ADDRESS
MODULE_ADDRESS=0xYOUR_MAINNET_MODULE_ADDRESS
GUARD_ADDRESS=0xYOUR_MAINNET_GUARD_ADDRESS

# --- PancakeSwap V3 Mainnet ---
PANCAKE_V3_FACTORY=0x0BFbCF9fa4f9C56B0F40a671Ad40E0805A091865
PANCAKE_SMART_ROUTER=0x13f4EA83D0bd40E75C8222255bc855a974568Dd4
PANCAKE_QUOTER_V2=0xB048Bbc1Ee6b733FFfCFb9e9CeF7375518e25997

# --- Oracle ---
PYTH_HERMES_URL=https://hermes.pyth.network

# --- Tuning ---
POLL_INTERVAL_MS=5000
MIN_PROFIT_MULTIPLIER=1.5
MIN_DEVIATION_BPS=50
MAX_CONSECUTIVE_FAILURES=5
SIMULATION_TIMEOUT_MS=10000
MAX_GAS_PRICE_MULTIPLIER=3

# --- Execution Controls ---
EXECUTION_MODE=canary
CANARY_MAX_TRADE_USD=50
RUNTIME_MAX_NOTIONAL_USD=500

# --- Telemetry ---
TELEMETRY_PORT=9100
TELEMETRY_BIND_ADDRESS=127.0.0.1
TELEMETRY_ALLOWED_ORIGIN=https://your-dashboard-domain
TELEMETRY_API_TOKEN=replace-with-long-random-telemetry-token

# --- Alerting ---
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
ALERT_MIN_SEVERITY=warn
ALERT_DEDUP_COOLDOWN_MS=300000
ALERT_POLICY_REJECTION_WINDOW_MIN=10
ALERT_POLICY_REJECTION_THRESHOLD=5
ALERT_ORACLE_NULL_WINDOW_MIN=10
ALERT_ORACLE_NULL_THRESHOLD=5
ALERT_RPC_CHECK_INTERVAL_MS=30000
ALERT_RPC_FAILURE_THRESHOLD=3
