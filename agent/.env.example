# ============================================================
# EquiliBot Agent Configuration
# Copy to .env and fill all values before running.
# ============================================================

# --- RPC Endpoints ---
# HTTP endpoint for read operations and Anvil forking
RPC_HTTP_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
# WebSocket endpoint for real-time event subscriptions (required)
RPC_WSS_URL=wss://your-quicknode-or-ankr-wss-endpoint
# Optional: Private RPC for transaction submission (MEV protection)
# RPC_PRIVATE_URL=
# Chain ID: 56 = BSC Mainnet, 97 = BSC Testnet
CHAIN_ID=97

# --- Agent Wallet ---
# SIGNER_MODE:
#   - local: uses AGENT_PRIVATE_KEY directly (allowed on testnets)
#   - managed: uses MANAGED_SIGNER_ADDRESS via private RPC signer infra (required on mainnet)
SIGNER_MODE=local

# Local signer key (required when SIGNER_MODE=local).
# DO NOT use this mode on mainnet.
AGENT_PRIVATE_KEY=0xYOUR_AGENT_PRIVATE_KEY

# Managed signer address (required when SIGNER_MODE=managed)
# MANAGED_SIGNER_ADDRESS=0xYOUR_MANAGED_SIGNER_ADDRESS

# Managed signer provider (mainnet production)
# MANAGED_SIGNER_PROVIDER=aws-kms
# AWS_REGION=us-east-1
# AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Private RPC endpoint for managed signer infra (required when SIGNER_MODE=managed)
# RPC_PRIVATE_URL=https://your-private-rpc-endpoint

# Mainnet safety gate: must be true when CHAIN_ID=56
SECURITY_REVIEW_SIGNED_OFF=false

# --- Deployed Phase 1 Contracts ---
SAFE_ADDRESS=0x19223058050D2C91E6e42158f0760340fB3d41c3
MODULE_ADDRESS=0xe963752aD278ff5185e16C46bB75C6c8b87641D6
GUARD_ADDRESS=0xba6c8EEaDB62Dc0302bEBb3d80C0AEA459af2Dc1

# --- PancakeSwap V3 ---
PANCAKE_V3_FACTORY=0x0BFbCF9fa4f9C56B0F40a671Ad40E0805A091865
PANCAKE_SMART_ROUTER=0x13f4EA83D0bd40E75C8222255bc855a974568Dd4
PANCAKE_QUOTER_V2=0xbC203d7f83677c7ed3F7acEc959963E7F4ECC5C2

# --- Pyth Oracle (off-chain) ---
PYTH_HERMES_URL=https://hermes.pyth.network

# --- Agent Tuning ---
# How often the agent polls for snapshots when WebSocket is idle (ms)
POLL_INTERVAL_MS=5000
# Minimum profit multiplier over gas cost (1.5 = profit must be 1.5x gas)
MIN_PROFIT_MULTIPLIER=1.5
# Minimum price deviation in basis points to trigger a rebalance check
MIN_DEVIATION_BPS=50
# Maximum consecutive failures before circuit breaker trips
MAX_CONSECUTIVE_FAILURES=5
# Simulation timeout (ms)
SIMULATION_TIMEOUT_MS=10000
# Maximum gas price multiplier over rolling average before blocking execution
MAX_GAS_PRICE_MULTIPLIER=3

# --- Execution Controls (Phase 3) ---
EXECUTION_MODE=observe
CANARY_MAX_TRADE_USD=50
RUNTIME_MAX_NOTIONAL_USD=0

# --- Telemetry ---
TELEMETRY_PORT=9100
TELEMETRY_BIND_ADDRESS=127.0.0.1
TELEMETRY_ALLOWED_ORIGIN=http://localhost:3000
# TELEMETRY_API_TOKEN=change-me-to-a-long-random-secret

# --- Alerting and Runtime Health Monitoring ---
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
ALERT_MIN_SEVERITY=warn
ALERT_DEDUP_COOLDOWN_MS=300000
ALERT_POLICY_REJECTION_WINDOW_MIN=10
ALERT_POLICY_REJECTION_THRESHOLD=5
ALERT_ORACLE_NULL_WINDOW_MIN=10
ALERT_ORACLE_NULL_THRESHOLD=5
ALERT_RPC_CHECK_INTERVAL_MS=30000
ALERT_RPC_FAILURE_THRESHOLD=3
